{
  "name": "edmond",
  "version": "1.0.0",
  "description": "Edmond Moepswa website on a public-only Cloudflare Worker",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" next build --webpack",
    "betterstack:ensure": "node ./src/scripts/ensure-betterstack-monitor.mjs",
    "db:migrate:launch": "node ./src/scripts/apply-launch-db-migration.mjs",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "cf:prepare": "node ./src/scripts/patch-opennext-cloudflare.mjs",
    "cf:postbuild": "node ./src/scripts/patch-opennext-cloudflare.mjs --postbuild",
    "cf:build": "pnpm cf:build:workers",
    "cf:build:workers": "node ./src/scripts/cloudflare-workers.mjs build --target local",
    "cf:deploy:prod": "node ./src/scripts/cloudflare-workers.mjs deploy --env production",
    "cf:deploy:staging": "node ./src/scripts/cloudflare-workers.mjs deploy --env staging",
    "cf:dev:workers": "node ./src/scripts/cloudflare-workers.mjs dev",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "preview": "pnpm cf:dev:workers",
    "deploy": "pnpm cf:deploy:prod",
    "cf:sync-secrets": "node --import=dotenv/config ./src/scripts/cloudflare-sync-secrets.mjs",
    "cf-typegen": "wrangler types --config wrangler.public.toml --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:verify:prod": "node ./src/scripts/cloudflare-workers.mjs verify --env production",
    "cf:verify:staging": "node ./src/scripts/cloudflare-workers.mjs verify --env staging",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" eslint src scripts tests next.config.ts open-next.config.ts playwright.config.ts redirects.ts vitest.config.mts tailwind.config.mjs eslint.config.mjs next-sitemap.config.cjs",
    "lint:fix": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" eslint src scripts tests next.config.ts open-next.config.ts playwright.config.ts redirects.ts vitest.config.mts tailwind.config.mjs eslint.config.mjs next-sitemap.config.cjs --fix",
    "make:sync": "node ./make-workflows/create-scenarios.mjs",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "typecheck": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1038.0",
    "@base-ui/react": "^1.3.0",
    "@calcom/embed-react": "^1.5.3",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "10.48.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.78",
    "@types/canvas-confetti": "^1.9.0",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.183.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "developer-icons": "^6.0.5",
    "dodopayments": "^2.27.0",
    "dotenv": "17.4.1",
    "geist": "^1.7.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "posthog-js": "^1.367.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "require-in-the-middle": "^8.0.1",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.8.2",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "^10.4.27",
    "critters": "^0.0.25",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "jsdom": "29.0.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.3",
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
