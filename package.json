{
  "name": "edmond-moepswa-cms",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@calcom/embed-react": "^1.5.3",
    "@payloadcms/admin-bar": "3.82.0",
    "@payloadcms/db-postgres": "3.82.0",
    "@payloadcms/live-preview-react": "3.82.0",
    "@payloadcms/next": "3.82.0",
    "@payloadcms/plugin-form-builder": "3.82.0",
    "@payloadcms/plugin-nested-docs": "3.82.0",
    "@payloadcms/plugin-redirects": "3.82.0",
    "@payloadcms/plugin-search": "3.82.0",
    "@payloadcms/plugin-seo": "3.82.0",
    "@payloadcms/richtext-lexical": "3.82.0",
    "@payloadcms/ui": "3.82.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.48.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.78",
    "@types/canvas-confetti": "^1.9.0",
    "@types/three": "^0.183.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "developer-icons": "^6.0.5",
    "dodopayments": "^2.27.0",
    "dotenv": "17.4.1",
    "geist": "^1.7.0",
    "graphql": "^16.13.2",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "payload": "3.82.0",
    "posthog-js": "^1.367.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "rss-parser": "^3.13.0",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "29.0.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
