# ==========================================
# Database (Neon PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ==========================================
# Payload CMS
# ==========================================
PAYLOAD_SECRET=your-secret-key-here
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=your-admin-password

# ==========================================
# Server
# ==========================================
NEXT_PUBLIC_SERVER_URL=https://edmond-moepswa.edmnd-src.workers.dev

# ==========================================
# Cal.com
# ==========================================
CAL_WEBHOOK_URL=https://hook.make.com/your-webhook
CAL_USERNAME=your-calcom-username
CAL_NAMESPACE=your-event-type

# ==========================================
# Make.com
# ==========================================
MAKE_API_TOKEN=your-make-api-token
MAKE_WEBHOOK_LEAD_CAPTURE=https://hook.make.com/PLACEHOLDER
MAKE_WEBHOOK_CALCULATOR_QUOTE=https://hook.make.com/PLACEHOLDER
MAKE_WEBHOOK_GUMROAD_DOWNLOAD=https://hook.me.com/PLACEHOLDER

# ==========================================
# Substack
# ==========================================
SUBSTACK_FEED_URL=https://yourname.substack.com/feed

# ==========================================
# Cron / scheduled jobs
# ==========================================
CRON_SECRET=your-cron-secret

# ==========================================
# Cloudflare R2 Media Storage
# ==========================================
R2_BUCKET=your-r2-bucket
R2_REGION=auto
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ==========================================
# Exchange Rate API
# ==========================================
# Free, no API key needed: https://api.exchangerate-api.com/v4/latest/BWP
