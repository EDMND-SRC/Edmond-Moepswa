# ==========================================
# Public App
# ==========================================
NEXT_PUBLIC_SERVER_URL=https://edmond.bridgearc.workers.dev
PREVIEW_SECRET=replace-with-a-random-secret

# ==========================================
# Database
# ==========================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ==========================================
# Dodo Payments
# ==========================================
DODO_PAYMENTS_API_KEY=dp_live_or_test_key
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_SECRET=replace-with-your-dodo-webhook-secret

# Optional product overrides if you do not want to rely on the committed launch snapshot.
DODO_PRODUCT_5_SIGNS_YOUR_WEBSITE_IS_COSTING_YOU_CLIENTS=pdt_xxx
DODO_PRODUCT_HOW_TO_BRIEF_A_WEB_DESIGNER=pdt_xxx
DODO_PRODUCT_WEBSITE_LAUNCH_CHECKLIST=pdt_xxx

# ==========================================
# Make.com
# ==========================================
MAKE_WEBHOOK_LEAD_CAPTURE=https://hook.make.com/your-lead-capture-hook
MAKE_WEBHOOK_CALCULATOR_QUOTE=https://hook.make.com/your-calculator-quote-hook
MAKE_WEBHOOK_RESOURCE_DOWNLOAD=https://hook.make.com/your-resource-download-hook
MAKE_WEBHOOK_DODO_PAYMENTS=https://hook.make.com/your-dodo-payments-hook

# ==========================================
# Cal.com
# ==========================================
CAL_WEBHOOK_URL=https://hook.make.com/your-cal-webhook
CAL_USERNAME=your-calcom-username
CAL_NAMESPACE=your-event-type

# ==========================================
# Cloudflare Runtime / Deploy
# ==========================================
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CRON_SECRET=your-cron-secret

# ==========================================
# Cloudflare R2 Media Storage
# ==========================================
R2_BUCKET=your-r2-bucket
R2_REGION=auto
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ==========================================
# Analytics / Social
# ==========================================
NEXT_PUBLIC_POSTHOG_API_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_API_KEY=phc_xxx
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your-handle
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/your-handle
NEXT_PUBLIC_SUBSTACK_URL=https://yourname.substack.com
NEXT_PUBLIC_THREADS_URL=https://threads.net/@your-handle
NEXT_PUBLIC_X_URL=https://x.com/your-handle
SUBSTACK_FEED_URL=https://yourname.substack.com/feed
